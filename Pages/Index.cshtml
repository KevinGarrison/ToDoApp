@page
@model IndexModel
@{
    ViewData["Title"] = "To-Do List";
}

<div class="container py-4">
    <h1 class="mb-3">To-Do List</h1>

    <form method="post" asp-page-handler="Add" class="row g-2 mb-3">
        <div class="col-sm-9 col-md-10">
            <input asp-for="NewTaskTitle" class="form-control" placeholder="Add a task" />
            <span asp-validation-for="NewTaskTitle" class="text-danger"></span>
        </div>
        <div class="col-sm-3 col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Add</button>
        </div>
    </form>

    @if (!Model.Tasks.Any())
    {
        <p class="text-muted">No tasks yet. Add your first task above.</p>
    }
    else
    {
        <ul class="list-group">
            @foreach (var task in Model.Tasks)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center gap-2">
                    <form method="post" asp-page-handler="Toggle" asp-route-id="@task.Id" class="d-flex align-items-center flex-grow-1">
                        <button type="submit" class="btn btn-sm @(task.IsCompleted ? "btn-success" : "btn-outline-secondary") me-2">
                            @(task.IsCompleted ? "Done" : "Mark Done")
                        </button>
                        <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">@task.Title</span>
                    </form>

                    <form method="post" asp-page-handler="Delete" asp-route-id="@task.Id">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </li>
            }
        </ul>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
